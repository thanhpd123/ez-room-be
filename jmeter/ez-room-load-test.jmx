        <hashTree/>

        <!-- Summary Report -->
        <ResultCollector guiclass="StatVisualizer" testclass="ResultCollector" testname="Summary Report" enabled="true">
          <elementProp name="ResultCollector.sample_filter_title_force_include_regex" elementType="TestElementProperty"/>
          <elementProp name="ResultCollector.sample_filter_title_force_exclude_regex" elementType="TestElementProperty"/>
          <elementProp name="ResultCollector.sample_filter_title_include_regex" elementType="TestElementProperty"/>
