# Server
PORT=3000
# Frontend origin for CORS (auth). Default: http://localhost:5173
# CORS_ORIGIN=http://localhost:5173

# Database (PostgreSQL – Supabase requires SSL)
# Add sslmode=require and connect_timeout=15 so Prisma doesn't hang.
# Prefer "Session" pooler (not Transaction) for db pull / migrate – same port 6543, different mode in dashboard.
# Example pooler: ...@aws-0-xx.pooler.supabase.com:6543/postgres?sslmode=require&connect_timeout=15
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@host:5432/postgres?sslmode=require&connect_timeout=15"

# Supabase (Auth + optional REST; for JWT verification and Supabase client)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
